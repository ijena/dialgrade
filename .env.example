# Copy this file to .env and fill in your values. NEVER commit the real .env.
# (.env is already in .gitignore)

# --- Vapi (voice calls) ---
# Use your PRIVATE key for server-side outbound calls (not the public key).
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# The number to audit. For the demo, this is YOUR cell. E.164 format: +1 then 10 digits.
TARGET_NUMBER=+15551234567

# --- Nebius Token Factory (scoring LLM) ---
# OpenAI-compatible endpoint. Confirm the base URL + model name in your Nebius dashboard.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Set to "local" to skip Nebius and score with the built-in rubric (good for testing
# the call path before your Nebius key works).
SCORER=nebius
